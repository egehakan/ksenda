# Turso Database Configuration
TURSO_DATABASE_URL="libsql://your-database-name.turso.io"
TURSO_AUTH_TOKEN="your_turso_auth_token"

# JWT secret for session cookies — change this to a long random string in production
JWT_SECRET="change-me-to-a-long-random-string"

# App Configuration
NEXT_PUBLIC_APP_URL="https://app.ksenda.com"

# Platform-level transactional email (Resend) — used for verification +
# password reset emails. This is SEPARATE from the per-user SMTP each tenant
# configures inside the app for their own outbound campaigns.
RESEND_API_KEY="re_your_resend_api_key"
RESEND_FROM_EMAIL="noreply@ksenda.com"
RESEND_FROM_NAME="Ksenda"

# Default user seeded by `npm run db:migrate` (only used the first time you
# run the migration on an existing database). Optional — defaults to a
# placeholder.
# DEFAULT_USER_EMAIL="admin@example.com"
# DEFAULT_USER_PASSWORD="change-me"

# NOTE
# - Apollo API key, Gemini API key, and per-user SMTP credentials are
#   configured per user inside the app (Settings tab). They are NOT env vars.
# - The RESEND_* vars above are ONLY used for verification + password
#   reset emails sent by the platform itself. The RESEND_FROM_EMAIL domain
#   must be verified in your Resend dashboard (Domains → Add → DNS records).
